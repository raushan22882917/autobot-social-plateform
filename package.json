{
  "name": "autobot360",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Social Commerce SaaS Platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=services/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "firebase:check": "node scripts/check-firebase-setup.mjs",
    "firebase:deploy-indexes": "firebase deploy --only firestore:indexes --project autobot-founder"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
