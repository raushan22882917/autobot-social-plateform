{
  "name": "autobot360",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Social Commerce SaaS Platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run build --workspace=packages/shared",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=services/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "rm -rf apps/web/.next services/api/dist packages/shared/dist",
    "clean:all": "npm run clean && rm -rf node_modules apps/web/node_modules services/api/node_modules packages/shared/node_modules",
    "firebase:check": "node scripts/check-firebase-setup.mjs",
    "vercel:env": "node scripts/vercel-sync-env.mjs",
    "vercel:deploy": "bash scripts/vercel-deploy.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
