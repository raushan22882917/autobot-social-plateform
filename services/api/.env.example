NODE_ENV=development
PORT=8081
# false = Firestore (cloud). true = in-memory only (data lost on restart)
USE_DEV_STORE=false
FORCE_FIREBASE_ADMIN=true

GCP_PROJECT_ID=autobot-founder
# false = in-process events only (no Cloud Pub/Sub topics needed for local dev)
PUBSUB_ENABLED=false
FIREBASE_PROJECT_ID=autobot-founder
FIREBASE_STORAGE_BUCKET=autobot-founder.firebasestorage.app
# Same value as NEXT_PUBLIC_FIREBASE_API_KEY in apps/web/.env.local
FIREBASE_WEB_API_KEY=
# Repo root (recommended) or path to downloaded Admin SDK key
FIREBASE_SERVICE_ACCOUNT_PATH=../../firebase-service-account.json

# Comma-separated emails granted platform superadmin (manage all users/stores)
PLATFORM_ADMIN_EMAILS=

JWT_SECRET=change-me
INTERNAL_API_KEY=internal-dev-key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:8081

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# YouTube uploads: public | unlisted | private (default unlisted)
YOUTUBE_DEFAULT_PRIVACY=unlisted
META_APP_ID=
META_APP_SECRET=
# Meta / WhatsApp webhook verify token (must match value in Meta Developer Console)
META_WEBHOOK_VERIFY_TOKEN=autobot360
META_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_SECRET=
# Optional: one-click connect on Social page (same Meta app as META_APP_ID)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Seller phone for new-order WhatsApp alerts (E.164 or 10-digit India)
WHATSAPP_NOTIFY_PHONE=
# Optional default publish audience (comma-separated). Prefer Social page → Publish recipients.
# WHATSAPP_PUBLISH_RECIPIENTS=

# WhatsApp Cloud API token connect. Set true to disable connect UI.
# WHATSAPP_CONNECT_DISABLED=true
TOKEN_ENCRYPTION_KEY=

# Poll interval for due scheduled posts (ms)
PUBLISH_POLL_INTERVAL_MS=30000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_VEO_MODEL=veo-3.1-generate-preview


HITEM3D_CLIENT_ID=
HITEM3D_CLIENT_SECRET=
HITEM3D_API_BASE_URL=https://api.hitem3d.ai
HITEM3D_MODEL=hitem3dv2.0
HITEM3D_RESOLUTION=1024
