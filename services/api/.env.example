NODE_ENV=development
PORT=8081
# false = Firestore (cloud). true = in-memory only (data lost on restart)
USE_DEV_STORE=false
FORCE_FIREBASE_ADMIN=true

GCP_PROJECT_ID=autobot-founder
FIREBASE_PROJECT_ID=autobot-founder
FIREBASE_STORAGE_BUCKET=autobot-founder.firebasestorage.app
FIREBASE_WEB_API_KEY=
# Repo root (recommended) or path to downloaded Admin SDK key
FIREBASE_SERVICE_ACCOUNT_PATH=../../firebase-service-account.json

# Comma-separated emails granted platform superadmin (manage all users/stores)
PLATFORM_ADMIN_EMAILS=

JWT_SECRET=change-me
INTERNAL_API_KEY=internal-dev-key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:8081

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# YouTube uploads: public | unlisted | private (default unlisted)
YOUTUBE_DEFAULT_PRIVACY=unlisted
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=77gtbg83kzx5wa
LINKEDIN_CLIENT_SECRET=WPL_AP1.90huINzydqmSrlGs.N3/hIA==
# Default: openid profile email w_member_social
# For company pages add (requires Marketing API approval):
# LINKEDIN_OAUTH_SCOPES=openid profile email w_member_social r_organization_social w_organization_social

# When true, posts publish via API (Instagram/Facebook) instead of n8n
DISABLE_N8N_AUTO_DISPATCH=true
# Poll interval for due scheduled posts (ms)
PUBLISH_POLL_INTERVAL_MS=30000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_VEO_MODEL=veo-2.0-generate-001
HITEM3D_CLIENT_ID=
HITEM3D_CLIENT_SECRET=
HITEM3D_API_BASE_URL=https://api.hitem3d.ai
HITEM3D_MODEL=hitem3dv2.0
HITEM3D_RESOLUTION=1024
